rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Authenticated users can read/write their own workspaces
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write boards
    match /boards/{boardId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write items
    match /items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write activities
    match /activities/{activityId} {
      allow read, write: if request.auth != null;
    }

    // Authenticated users can read/write notifications
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
  }
}
